DROP DATABASE if EXISTS compras;
CREATE DATABASE compras;
use compras;
CREATE TABLE provincia(id_provincia int PRIMARY KEY AUTO_INCREMENT, nombre varchar(20), pais varchar(20));
CREATE TABLE ciudad (id_ciudad int PRIMARY KEY AUTO_INCREMENT, nombre varchar(30), cantidad_habitantes int (10), codigopostal int(8), id_provincia int, FOREIGN KEY(id_provincia) REFERENCES provincia(id_provincia)); 
create TABLE cliente(cliente_id int PRIMARY KEY AUTO_INCREMENT, nombre varchar(20), dni int(20), apellido varchar(20), telefono varchar(30), gmail varchar(30), id_ciudad int, FOREIGN KEY (id_ciudad) REFERENCES ciudad(id_ciudad));
create TABLE productos(id_productos int PRIMARY KEY AUTO_INCREMENT, nombre varchar(30), precio decimal(20));
create TABLE compras(pedido_id int PRIMARY KEY AUTO_INCREMENT, fecha varchar(20), cantidadproductos varchar (10), preciototal varchar(10)); 

